# Server Configuration
PORT=5000
MONGODB_URI=your_mongodb_uri_here
ADMIN_PASSWORD=your_admin_password_here

# Superadmin Configuration
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=your_superadmin_password_here

# Google Integration (Optional for local dev unless using Google features)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_SHEET_ID=your_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email_here
GOOGLE_PRIVATE_KEY="your_private_key_here"
GOOGLE_SHEET_ID_CUSTOMERS=your_customer_sheet_id_here
GOOGLE_SHEET_ID_BUSINESSES=your_business_sheet_id_here

# Notifications (Email)
GMAIL_USER=your_gmail_here
GMAIL_PASS=your_gmail_app_password_here
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_API_SECRET=your_mailjet_api_secret
MAILJET_SENDER_EMAIL=your_sender_email_here

# Resend (Preferred Email Provider - sign up free at resend.com)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Firebase Admin SDK (Required for backend)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="your_firebase_private_key_here"

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

# General
SESSION_SECRET=your_session_secret_here
FRONTEND_URL=http://localhost:5173

# Razorpay (Payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_PLAN_ID=your_razorpay_plan_id

# Email Service Provider Toggle
USE_FIREBASE_EMAIL=false
